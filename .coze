[project]
requires = [ "nodejs-24" ]
template = "vite"
version = "0.0.27"
appliedPatches = [ ]

[dev]
build = [ "pnpm", "install" ]
run = [ "pnpm", "run", "dev" ]
deps = [ "git" ]

[deploy]
build = [ "pnpm", "run", "build" ]
run = [ "npx", "serve", "dist", "-l", "5000", "--no-clipboard" ]
deps = [ "git" ]
